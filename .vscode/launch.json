{
  "version": "0.2.0",
  "configurations": [
    
    {
      "name": "Go: Debug (workspace)",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/src",
      "cwd": "${workspaceFolder}/src",
      "args": [],
      "env": {},
      "console": "integratedTerminal"
    },
    {
      "name": "Go: Debug tests (all)",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/src",
      "cwd": "${workspaceFolder}/src",
      "args": [],
      "env": {},
      "console": "integratedTerminal"
    },
    {
      "name": "C/C++ Runner: Debug Session",
      "type": "cppdbg",
      "request": "launch",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": true,
      "cwd": "${workspaceFolder}/src",
      "program": "${workspaceFolder}/src/c-lexer.exe",
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}